<ChangePassword>
    name: "change_password"
    MDFloatLayout:
        md_bg_color: self.theme_cls.backgroundColor
        MDTopAppBar:
            pos_hint: {"top": 1.0}
            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "close"
                    on_release: app.root.current = "home"

        MDLabel:
            text: "修改密码"
            halign: "center"
            pos_hint: {"center_y": 0.8}
            font_style: "Title"

        # 原密码
        MDTextField:
            id: old_password
            mode: "filled"
            password: True
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5, "center_y": 0.68}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "lock"
            MDTextFieldHintText:
                text: "原密码"

        # 新密码
        MDTextField:
            id: new_password
            mode: "filled"
            password: True
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5, "center_y": 0.56}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "lock"
            MDTextFieldHintText:
                text: "新密码"
            MDTextFieldHelperText:
                text: "长度为10~20，可以是大小写字母和数字"

        # 确认密码
        MDTextField:
            id: new_password_confirm
            mode: "filled"
            password: True
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5, "center_y": 0.44}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "lock-check"
            MDTextFieldHintText:
                text: "确认新密码"

        # 修改密码按钮（和登录完全一致）
        MDButton:
            style: "filled"
            pos_hint: {"center_x": 0.5, "center_y": 0.32}
            theme_width: "Custom"
            size_hint_x: .8
            on_release: root.change_password()
            MDButtonText:
                pos_hint: {"center_x": .5, "center_y": .5}
                text: "修改密码"
