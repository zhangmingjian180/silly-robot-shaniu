<ChangePhone>
    name: "change_phone"
    MDFloatLayout:
        md_bg_color: self.theme_cls.backgroundColor
        MDTopAppBar:
            pos_hint: {"top": 1.0}
            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "close"
                    on_release: app.root.current = "home"

        MDLabel:
            text: "修改手机"
            halign: "center"
            pos_hint: {"center_y": 0.92}
            font_style: "Title"

        # 🖼 图形验证码输入
        MDTextField:
            id: old_phone_captcha_code
            mode: "filled"
            size_hint_x: 0.5
            pos_hint: {"center_x": 0.35, "center_y": 0.80}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "shield-key"
            MDTextFieldHintText:
                text: "验证码"

        # 🖼 图形验证码图片（点击刷新）
        FitImage:
            id: old_phone_captcha_img
            size_hint: None, None
            size: "120dp", "40dp"
            pos_hint: {"right": 0.9, "center_y": 0.80}
            on_touch_down:
                if self.collide_point(*args[1].pos): root.update_old_phone_captcha()

        # 📲 短信验证码输入 + 按钮
        MDTextField:
            id: old_phone_sms_code
            mode: "filled"
            size_hint_x: 0.5
            pos_hint: {"center_x": 0.35, "center_y": 0.68}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "message-text"
            MDTextFieldHintText:
                text: "原手机短信验证码"
 
        # 📩 获取验证码按钮（带倒计时）
        MDButton:
            id: old_phone_btn_send_code
            style: "tonal"
            radius: dp(10)
            pos_hint: {"right": 0.9, "center_y": 0.68}
            on_release: root.send_old_phone_sms_code()
            MDButtonText:
                id: old_phone_btn_send_code_text
                text: "获取验证码"

        # 新手机号
        MDTextField:
            id: phone
            mode: "filled"
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5, "center_y": 0.56}
            input_filter: "int"
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "cellphone"
            MDTextFieldHintText:
                text: "新手机号"

        # 🖼 图形验证码输入
        MDTextField:
            id: captcha_code
            mode: "filled"
            size_hint_x: 0.5
            pos_hint: {"center_x": 0.35, "center_y": 0.44}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "shield-key"
            MDTextFieldHintText:
                text: "验证码"

        # 🖼 图形验证码图片（点击刷新）
        FitImage:
            id: new_phone_captcha_img
            size_hint: None, None
            size: "120dp", "40dp"
            pos_hint: {"right": 0.9, "center_y": 0.44}
            on_touch_down:
                if self.collide_point(*args[1].pos): root.update_new_phone_captcha()

        # 📲 短信验证码输入 + 按钮
        MDTextField:
            id: sms_code
            mode: "filled"
            size_hint_x: 0.5
            pos_hint: {"center_x": 0.35, "center_y": 0.32}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "message-text"
            MDTextFieldHintText:
                text: "新手机短信验证码"
 
        # 📩 获取验证码按钮（带倒计时）
        MDButton:
            id: btn_send_code
            style: "tonal"
            radius: dp(10)
            pos_hint: {"right": 0.9, "center_y": 0.32}
            on_release: root.send_sms_code()
            MDButtonText:
                id: btn_send_code_text
                text: "获取验证码"

        # 🚀 重置密码按钮（和登录完全一致）
        MDButton:
            style: "filled"
            pos_hint: {"center_x": 0.5, "center_y": 0.20}
            theme_width: "Custom"
            size_hint_x: .8
            on_release: root.change_phone()
            MDButtonText:
                pos_hint: {"center_x": .5, "center_y": .5}
                text: "修改手机号"
