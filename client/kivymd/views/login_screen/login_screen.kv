<LoginScreen>
    name: "login"
    MDFloatLayout:
        md_bg_color: self.theme_cls.backgroundColor
        MDTopAppBar:
            pos_hint: {"top": 1.0}
            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "close"
                    on_release: root.close()

        MDLabel:
            text: "登录系统"
            halign: "center"
            pos_hint: {"center_y": 0.8}
            font_style: "Title"

        MDTextField:
            id: username
            mode: "filled"
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5, "center_y": 0.65}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "cellphone"
            MDTextFieldHintText:
                text: "手机号"

        MDTextField:
            id: password
            mode: "filled"
            password: True
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "lock"
            MDTextFieldHintText:
                text: "密码"

        MDButton:
            style: "filled"
            pos_hint: {"center_x": 0.5, "center_y": 0.35}
            theme_width: "Custom"
            size_hint_x: .8
            on_release: app.root.get_screen("login").login()
            MDButtonText:
                pos_hint: {"center_x": .5, "center_y": .5}
                text: "登录"

        # 注册按钮
        MDButton:
            style: "text"
            pos_hint: {"center_x": 0.3, "center_y": 0.25}
            on_release: app.root.current = "register"
            MDButtonText:
                text: "注册账号"

        # 忘记密码
        MDButton:
            style: "text"
            pos_hint: {"center_x": 0.7, "center_y": 0.25}
            on_release: app.root.current = "forgot"
            MDButtonText:
                text: "忘记密码"

    MDCircularProgressIndicator:
        id: loading_circular
        active: False
        size_hint: 0.1, 0.1
        pos_hint: {'center_x': .5, 'center_y': .5}
