<DeleteAccountDialog>
    MDDialogIcon:
        icon: "trash-can-outline"
    MDDialogHeadlineText:
        text: "删除"
    MDDialogSupportingText:
        text: '确认是否注销账号（注销后无法撤回）?'
        halign: "left"
    MDDialogButtonContainer:
        Widget:
        MDButton:
            style: "text"
            on_release: root.dismiss()
            MDButtonText:
                text: "取消"
        MDButton:
            style: "text"
            on_release: root.click_button()
            MDButtonText:
                text: "确定"

<DeleteAccount>
    name: "delete_account"
    MDFloatLayout:
        md_bg_color: self.theme_cls.backgroundColor
        MDTopAppBar:
            pos_hint: {"top": 1.0}
            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "close"
                    on_release: app.root.current = "home"

        MDLabel:
            text: "注销账号"
            halign: "center"
            pos_hint: {"center_y": 0.8}
            font_style: "Title"

        # 🖼  图形验证码输入
        MDTextField:
            id: del_captcha
            mode: "filled"
            size_hint_x: 0.5
            pos_hint: {"center_x": 0.35, "center_y": 0.68}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "shield-key"
            MDTextFieldHintText:
                text: "验证码"

        # 🖼  图形验证码图片（点击刷新）
        FitImage:
            id: captcha_img
            size_hint: None, None
            size: "120dp", "40dp"
            pos_hint: {"right": 0.9, "center_y": 0.68}
            on_touch_down:
                if self.collide_point(*args[1].pos): root.update_captcha()

        # 📲 短信验证码输入 + 按钮
        MDTextField:
            id: del_sms_code
            mode: "filled"
            size_hint_x: 0.5
            pos_hint: {"center_x": 0.35, "center_y": 0.56}
            theme_bg_color: "Custom"
            fill_color_normal: self.theme_cls.backgroundColor
            fill_color_focus: self.theme_cls.backgroundColor
            MDTextFieldTrailingIcon:
                icon: "message-text"
            MDTextFieldHintText:
                text: "短信验证码"

        # 📩 获取验证码按钮（带倒计时）
        MDButton:
            id: btn_send_code
            style: "tonal"
            radius: dp(10)
            pos_hint: {"right": 0.9, "center_y": 0.56}
            on_release: root.send_sms_code()
            MDButtonText:
                id: btn_send_code_text
                text: "获取验证码"

        MDButton:
            style: "filled"
            pos_hint: {"center_x": 0.5, "center_y": 0.44}
            theme_width: "Custom"
            size_hint_x: .8
            theme_bg_color: "Custom"
            md_bg_color: "red"
            on_release: root.click_button()
            MDButtonText:
                pos_hint: {"center_x": .5, "center_y": .5}
                text: "注销账号"
