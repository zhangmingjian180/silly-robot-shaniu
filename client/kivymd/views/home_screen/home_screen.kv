<RenameDialog>
    headline: headline
    MDDialogIcon:
        icon: "pencil-outline"
    MDDialogHeadlineText:
        text: "重命名"
    MDDialogSupportingText:
        id: headline
        text: "请输入新名："
        halign: "left"
    MDDialogContentContainer:
        orientation: "vertical"
        MDTextField:
            id: newname
            required: True
            size_hint_x: 1.0
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            text: root.robot_name
    MDDialogButtonContainer:
        Widget:
        MDButton:
            style: "text"
            on_release: root.dismiss()
            MDButtonText:
                text: "取消"
        MDButton:
            style: "text"
            on_release: root.rename()
            MDButtonText:
                text: "确定"

<InfoDialog>
    MDDialogIcon:
        icon: "information"
    MDDialogHeadlineText:
        text: "详细信息"
    MDDialogSupportingText:
        halign: "left"
        text: root.robot_info
    MDDialogButtonContainer:
        Widget:
        MDButton:
            style: "text"
            on_release: root.dismiss()
            MDButtonText:
                text: "确定"

<DeleteDialog>
    headline: headline
    MDDialogIcon:
        icon: "trash-can-outline"
    MDDialogHeadlineText:
        text: "删除"
    MDDialogSupportingText:
        id: headline
        text: '确认是否删除 "%s" ?' % root.robot_name
        halign: "left"
    MDDialogButtonContainer:
        Widget:
        MDButton:
            style: "text"
            on_release: root.dismiss()
            MDButtonText:
                text: "取消"
        MDButton:
            style: "text"
            on_release: root.delete_robot()
            MDButtonText:
                text: "确定"

<RobotCard>
    orientation: "vertical"
    size_hint_x: .8
    size_hint_y: None
    height: "256dp"
    pos_hint: {"center_x": .5}
    padding: "16dp"
    MDBoxLayout:
        size_hint_y: None
        height: "40dp"
        MDIconButton:
            pos_hint: {"center_y": .5}
            icon: "wifi-cog"
            on_release: root.goto_wifi_configure()
        Widget:
        MDIconButton:
            id: card_menu_module
            pos_hint: {"center_y": .5}
            icon: "menu"
            on_release: root.menu_open()
    MDDivider:
    MDLabel:
        id: label
        text: "机器人模板"
        halign: "center"
        valign: "middle"
        font_style: "Title"
    Widget:
        size_hint_y: None
        height: "20dp"

<HomeScreen>
    name: "home"

    MDBoxLayout:
        id: box
        md_bg_color: self.theme_cls.backgroundColor
        orientation: "vertical"

        MDTopAppBar:
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "logout"
                    on_release: app.root.current = "login"
            MDTopAppBarTitle:
                text: "首页"
                halign: "center"
            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "theme-light-dark"
                    on_release: root.switch_theme()

        ScrollView:
            MDList:
                id: box_r
                spacing: "16dp"
                padding: "32dp", "0dp", "32dp", "32dp"

                MDCard:
                    orientation: "vertical"
                    size_hint_x: .8
                    size_hint_y: None
                    height: "256dp"
                    pos_hint: {"center_x": .5}
                    padding: "16dp"
                    style: "outlined"
                    on_release: root.goto_add_robot()
                    MDLabel:
                        text: "添加机器人"
                        halign: "center"
                        font_style: "Title"
                    MDIcon:
                        icon: "plus"
                        pos_hint: {"center_x": .5}
